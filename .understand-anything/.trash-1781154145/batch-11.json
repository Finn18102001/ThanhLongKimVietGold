{
  "nodes": [
    {
      "id": "file:server.js",
      "type": "file",
      "name": "server.js",
      "filePath": "server.js",
      "summary": "Express application entry point that polyfills fetch globals, loads environment variables, creates the Express app, registers all routes via routes/index.js, and starts an HTTP server with automatic port-increment retry when the base port is busy.",
      "tags": ["entry-point", "express", "server", "http", "routing"],
      "complexity": "moderate",
      "languageNotes": "Bootstraps with require('./lib/node-fetch-globals') before any Supabase client code and delegates route mounting to routes/index.js."
    },
    {
      "id": "file:upstream-home.js",
      "type": "file",
      "name": "upstream-home.js",
      "filePath": "upstream-home.js",
      "summary": "Legacy upstream homepage client script (707 lines) that initializes Swiper carousels for banners and product sliders, AOS scroll animations, a Chart.js gold-rate line chart fed by /api/v1/exchangerate/goldRateChart, and jQuery-driven login/register modal flows with province/district/ward cascading dropdowns.",
      "tags": ["javascript", "legacy", "homepage", "swiper", "chart", "auth"],
      "complexity": "complex",
      "languageNotes": "Global script with no module exports; functions are invoked from inline HTML handlers and jQuery window-load bindings rather than ES module imports."
    },
    {
      "id": "file:thuong-hieu/index.html",
      "type": "file",
      "name": "index.html",
      "filePath": "thuong-hieu/index.html",
      "summary": "Brand-scoped product catalog page shell served at /thuong-hieu/:brandSlug. Provides a back link to the full catalog, an empty header filled by site-nav.js, a #brand-catalog-root mount point hydrated by brand-page.js, global footer chrome, and Supabase-backed product scripts.",
      "tags": ["html", "products", "brand-page", "catalog", "supabase"],
      "complexity": "moderate",
      "languageNotes": "Loads 8 stylesheets and 14 JavaScript modules; page title and meta are rewritten client-side after the brand slug is resolved."
    },
    {
      "id": "function:server.js:listenFrom",
      "type": "function",
      "name": "listenFrom",
      "filePath": "server.js",
      "lineRange": [18, 42],
      "summary": "Creates an HTTP server wrapping the Express app and listens on the given port. On EADDRINUSE, recursively retries the next port up to triesLeft attempts; otherwise logs startup URLs and exits on fatal errors.",
      "tags": ["server", "port-binding", "error-handling", "startup"],
      "complexity": "moderate"
    },
    {
      "id": "function:upstream-home.js:getGoldrateByTime",
      "type": "function",
      "name": "getGoldrateByTime",
      "filePath": "upstream-home.js",
      "lineRange": [330, 337],
      "summary": "Async fetch wrapper that requests gold rate chart JSON from /api/v1/exchangerate/goldRateChart with gold_type, time_type, and init query parameters.",
      "tags": ["api-client", "gold-pricing", "fetch", "chart-data"],
      "complexity": "simple"
    },
    {
      "id": "function:upstream-home.js:getGolRateByType",
      "type": "function",
      "name": "getGolRateByType",
      "filePath": "upstream-home.js",
      "lineRange": [339, 385],
      "summary": "Loads gold rate time-series for a given gold type and time window (day/week/month/year), builds Chart.js time-axis options per granularity, stores the result in module-level json, and renders the chart via initChart.",
      "tags": ["gold-pricing", "chart", "time-axis", "data-loader"],
      "complexity": "moderate"
    },
    {
      "id": "function:upstream-home.js:initChart",
      "type": "function",
      "name": "initChart",
      "filePath": "upstream-home.js",
      "lineRange": [393, 485],
      "summary": "Builds or replaces a Chart.js line chart on #myChart showing buy (rate) and sell datasets with time-scale x-axis, right-side y-axis, and brand-colored styling. Destroys any existing chart instance before re-rendering.",
      "tags": ["chart", "chartjs", "visualization", "gold-pricing"],
      "complexity": "complex"
    },
    {
      "id": "function:upstream-home.js:updateChart",
      "type": "function",
      "name": "updateChart",
      "filePath": "upstream-home.js",
      "lineRange": [487, 491],
      "summary": "Chart refresh handler triggered by radio-button time-range changes; logs the selected chartType and re-invokes initChart (data variables are currently uninitialized in this stub path).",
      "tags": ["chart", "event-handler", "gold-pricing"],
      "complexity": "simple"
    },
    {
      "id": "function:upstream-home.js:login_function",
      "type": "function",
      "name": "login_function",
      "filePath": "upstream-home.js",
      "lineRange": [493, 502],
      "summary": "Toggles the login/register modal overlay by adding or removing the active class on .function_login based on the modalResigter element display state.",
      "tags": ["auth", "modal", "ui-toggle", "jquery"],
      "complexity": "simple"
    },
    {

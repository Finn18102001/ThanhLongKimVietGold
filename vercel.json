{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "includeFiles": "{*.html,robots.txt,sitemap.xml,site.webmanifest,local.css,admin/**,assets/**,css/**,js/**,data/**,gioi-thieu/**,san-pham/**,tin-tuc/**,thuong-hieu/**,routes/**}"
      }
    }
  ],
  "routes": [
    { "src": "/assets/logo-tv-modal.svg", "status": 301, "headers": { "Location": "/assets/tlkv-logo-mark.png?v=20260623" } },
    { "src": "/assets/logo-thang-long-kim-viet.png", "status": 301, "headers": { "Location": "/assets/tlkv-logo-mark.png?v=20260623" } },
    { "src": "/assets/logo-thanglong-kim-viet.png", "status": 301, "headers": { "Location": "/assets/tlkv-logo-mark.png?v=20260623" } },
    { "src": "/admin/news/edit/([0-9a-fA-F-]+)", "dest": "server.js" },
    { "src": "/admin/news/new", "dest": "server.js" },
    { "src": "/admin/news", "dest": "server.js" },
    { "src": "/admin/news.html", "dest": "server.js" },
    { "src": "/tin-tuc/danh-sach", "dest": "server.js" },
    { "src": "/tin-tuc/thi-truong", "dest": "server.js" },
    { "src": "/tin-tuc/chi-tiet/([^/]+)", "dest": "server.js" },
    { "src": "/tin-tuc/([^/]+)", "dest": "server.js" },
    { "src": "/tin-tuc", "dest": "server.js" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}

{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "includeFiles": [
          "index.html",
          "tv-model.html",
          "homepage.html",
          "gia-vang-hom-nay.html",
          "googlea0e5d99f07f9bb75.html",
          "admin/**",
          "assets/**",
          "css/**",

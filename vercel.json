{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60,
        "includeFiles": "{*.html,local.css,admin/**,assets/**,css/**,js/**,data/**,gioi-thieu/**,san-pham/**,tin-tuc/**,thuong-hieu/**}"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ]
}

# --- Cách 1: tên giống Supabase Dashboard (Connect) / Next.js ---
# Sao chép vào .env hoặc .env.local (ưu tiên .env.local nếu cả hai đều có)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Hoặc dùng anon key (Project Settings → API) thay cho publishable:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Cách 2: tên ngắn (vẫn hỗ trợ) ---
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=eyJ...

# Optional (server)
# PORT=5190

# Sao chép thành .env hoặc .env.local (ưu tiên .env.local). Hai file đó KHÔNG commit — chỉ cấu hình trên máy / trên host.
# Xem README.md mục "Deploy — biến môi trường".

# --- Cách 1: tên giống Supabase Dashboard (Connect) / Next.js ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Hoặc dùng anon key (Project Settings → API) thay cho publishable:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Cách 2: tên ngắn (vẫn hỗ trợ) ---
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=eyJ...

# Optional (server)
# PORT=5190

# --- GoldAPI (chỉ server) — giá XAU/USD: /api/world-xau-usd ---
# Lấy key: https://www.goldapi.io/dashboard
# Production: đặt GOLDAPI_KEY trong dashboard host (Vercel/Railway/Render/VPS…), không ghi key thật vào Git.
GOLDAPI_KEY=

# Tên thay thế (nếu đã đặt sẵn trên host):
# GOLDAPI_IO_KEY=
